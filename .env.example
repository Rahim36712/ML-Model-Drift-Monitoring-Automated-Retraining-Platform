# MLOps Drift Monitor - Environment Variables
# Copy this file to .env and fill in your values

# Slack (optional - alerts default to console if not set)
SLACK_WEBHOOK_URL=

# Email (optional - alerts default to console if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# MLflow
MLFLOW_TRACKING_URI=sqlite:///mlruns/mlflow.db

# API
API_HOST=0.0.0.0
API_PORT=8000

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8050
